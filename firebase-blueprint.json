{
  "entities": {
    "Tenant": {
      "title": "Tenant",
      "description": "Enterprise tenant configuration",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "features": { "type": "object" },
        "settings": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "Asset": {
      "title": "Asset",
      "description": "Fixed asset item",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "name": { "type": "string" },
        "categoryId": { "type": "string" },
        "branchId": { "type": "string" },
        "status": { "type": "string" },
        "purchaseValue": { "type": "number" },
        "bookValue": { "type": "number" },
        "tenant_id": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "name", "tenant_id"]
    },
    "MaintenanceTicket": {
      "title": "Maintenance Ticket",
      "description": "Repair or service request",
      "type": "object",
      "properties": {
        "assetId": { "type": "string" },
        "status": { "type": "string" },
        "description": { "type": "string" },
        "tenantId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["assetId", "status", "tenantId"]
    },
    "SupportTicket": {
      "title": "Support Ticket",
      "description": "Global support request from a tenant",
      "type": "object",
      "properties": {
        "tenant_id": { "type": "string" },
        "subject": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "in_progress", "waiting", "resolved", "closed"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "urgent"] },
        "assigned_to": { "type": "string" },
        "sla_response_due": { "type": "string", "format": "date-time" },
        "sla_resolution_due": { "type": "string", "format": "date-time" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "support_tickets/{ticketId}": {
      "schema": "SupportTicket",
      "description": "Global support requests"
    },
    "tenants/{tenantId}": {
      "schema": "Tenant",
      "description": "Root tenant document"
    },
    "tenants/{tenantId}/assets/{assetId}": {
      "schema": "Asset",
      "description": "Asset subcollection"
    },
    "tenants/{tenantId}/maintenance_tickets/{ticketId}": {
      "schema": "MaintenanceTicket",
      "description": "Maintenance subcollection"
    }
  }
}

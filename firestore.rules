rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default global deny to ensure security gaps are closed
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSameTenant(tenantId) {
      return request.auth != null && request.auth.token.tenant_id == tenantId;
    }

    function isPlatformAdmin() {
      return request.auth != null && request.auth.token.is_platform_admin == true;
    }

    function hasPermission(permKey) {
      return request.auth != null 
             && request.auth.token.permissions != null 
             && request.auth.token.permissions[permKey] == true;
    }

    function isResourceOwner() {
      return request.auth != null && request.auth.uid == resource.data.created_by;
    }

    // Base Tenant Root Operations
    match /tenants/{tenantId} {
      allow read: if isPlatformAdmin();
      allow write: if isPlatformAdmin();

      // Asset Data Subcollections
      match /assets/{assetId} {
        allow read: if isSameTenant(tenantId);
        allow create: if isSameTenant(tenantId) && hasPermission("asset_register.create");
        allow update: if isSameTenant(tenantId) && hasPermission("asset_register.edit");
        allow delete: if isSameTenant(tenantId) && hasPermission("asset_register.delete");
      }

      // Depreciation Logs (Server-side generated only)
      match /depreciation_logs/{logId} {
        allow read: if isSameTenant(tenantId);
        allow write: if false; // Server-only Admin SDK
      }

      // Audit and Access Trace Logging (Server-only write)
      match /activity_logs/{logId} {
        allow read: if isSameTenant(tenantId) && hasPermission("audit_log.view");
        allow write: if false; // Server-only Admin SDK
      }

      // Physical Audit Campaigns
      match /audit_campaigns/{campaignId} {
        allow read: if isSameTenant(tenantId) && hasPermission("audit.view");
        allow create: if isSameTenant(tenantId) && hasPermission("audit.create");
        allow update: if isSameTenant(tenantId) && hasPermission("audit.edit");
        allow delete: if isSameTenant(tenantId) && hasPermission("audit.delete");
      }

      // Multi-Channel Notifications User Inboxes
      match /notifications/{notifId} {
        // Enforce strong isolation per-user inbox
        allow read: if isSameTenant(tenantId) && resource.data.user_id == request.auth.uid;
        allow write: if false; // Server-only notification engine
      }
    }
  }
}
